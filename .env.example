# Canonical production URL (used for sitemap, Open Graph, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://www.justifiedtechnical.ae

# EmailJS — https://www.emailjs.com/
# Template variables: subject, message_html, to_email, from_name, reply_to
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key

# Recipient inbox for contact form submissions
NEXT_PUBLIC_CONTACT_TO_EMAIL=your-inbox@example.com
